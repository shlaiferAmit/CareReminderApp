<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ChangeProfilePage"
             x:DataType="viewmodels:ChangeProfileViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True"
             FlowDirection="LeftToRight"
             Title="Edit Profile">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Start">

            <Label Text="Edit Profile" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#2C3E50"
                   Margin="0,10,0,10"/>

            <VerticalStackLayout Spacing="15">

                <VerticalStackLayout Spacing="5">
                    <Label Text="Email Address (Locked)" 
                           FontSize="14" 
                           TextColor="#34495E" 
                           HorizontalTextAlignment="Start"/>
                    <Frame BackgroundColor="#ECF0F1" 
                           BorderColor="#BDC3C7" 
                           Padding="15,12" 
                           CornerRadius="10" 
                           HasShadow="False">
                        <HorizontalStackLayout Spacing="10" FlowDirection="LeftToRight">
                            <Label Text="✉️" VerticalOptions="Center"/>
                            <Label Text="{Binding EditableUser.UserEmail}" 
                                   TextColor="#7F8C8D" 
                                   FontAttributes="Italic"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Start"/>
                        </HorizontalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="First Name" FontSize="14" TextColor="#34495E" HorizontalTextAlignment="Start"/>
                    <Frame Padding="5,2" CornerRadius="10" HasShadow="False" BackgroundColor="White" BorderColor="#BDC3C7">
                        <Entry Placeholder="Enter first name" 
                               Text="{Binding EditableUser.FirstName, Mode=TwoWay}" 
                               TextColor="#2C3E50"
                               HorizontalTextAlignment="Start"
                               FlowDirection="LeftToRight"/>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Last Name" FontSize="14" TextColor="#34495E" HorizontalTextAlignment="Start"/>
                    <Frame Padding="5,2" CornerRadius="10" HasShadow="False" BackgroundColor="White" BorderColor="#BDC3C7">
                        <Entry Placeholder="Enter last name" 
                               Text="{Binding EditableUser.LastName, Mode=TwoWay}" 
                               TextColor="#2C3E50"
                               HorizontalTextAlignment="Start"
                               FlowDirection="LeftToRight"/>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Phone Number" FontSize="14" TextColor="#34495E" HorizontalTextAlignment="Start"/>
                    <Frame Padding="5,2" CornerRadius="10" HasShadow="False" BackgroundColor="White" BorderColor="#BDC3C7">
                        <Entry Placeholder="e.g. 0501234567" 
                               Text="{Binding EditableUser.Mobile, Mode=TwoWay}" 
                               TextColor="#2C3E50"
                               Keyboard="Telephone"
                               HorizontalTextAlignment="Start"
                               FlowDirection="LeftToRight"/>
                    </Frame>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <Button Text="SAVE CHANGES"
                    BackgroundColor="#3498DB"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="18"
                    CornerRadius="25"
                    HeightRequest="60"
                    Margin="0,20,0,0"
                    Command="{Binding SaveChangesCommand}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>