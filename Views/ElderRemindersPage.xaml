<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ElderRemindersPage"
             x:DataType="viewmodels:TodayRemindersViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, 70">

        <VerticalStackLayout Grid.Row="0" Margin="20,10">
            <HorizontalStackLayout Spacing="5">
                <Image Source="logout_icon.png" WidthRequest="20"/>
                <Label Text="Logout" VerticalOptions="Center" TextColor="#2C3E50"/>
            </HorizontalStackLayout>
            <Image Source="family_logo.png" HeightRequest="100" Margin="0,10"/>
            <Label Text="Welcome Home!" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
            <Label Text="CareRemind" FontSize="20" HorizontalOptions="Center" TextColor="#546E7A"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="15" Margin="30,10">
            <Frame BackgroundColor="#E67E22" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                <VerticalStackLayout>
                    <Label Text="{Binding WelcomeGreeting}" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="{Binding RemindersSummary}" TextColor="White" FontSize="16" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#1ABC9C" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                <VerticalStackLayout>
                    <Label Text="Upcoming Remind:" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="{Binding UpcomingReminder.Title}" TextColor="White" FontSize="18" HorizontalOptions="Center"/>
                    <Label Text="{Binding UpcomingReminder.Time, StringFormat='{0:HH:mm}'}" TextColor="White" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="+ Add family member" BackgroundColor="#8E44AD" TextColor="White" CornerRadius="15" HeightRequest="60" FontAttributes="Bold"/>
        </VerticalStackLayout>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" BackgroundColor="White" Padding="5">
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToTodayRemindersCommand}"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="Today's Remind" HorizontalOptions="Center" TextColor="#2C3E50" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToProfileCommand}"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="My Profile" HorizontalOptions="Center" TextColor="Gray"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>