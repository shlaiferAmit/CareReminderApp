<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.ElderRemindersPage"
             x:DataType="viewmodels:ElderRemindersViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,10,0,20">
            <Image Source="logo.png" HeightRequest="100" HorizontalOptions="Center"/>
            <Label Text="Welcome Home!" 
                   FontSize="32" FontAttributes="Bold" 
                   TextColor="#2C3E50" HorizontalOptions="Center"/>
            <Label Text="CareRemind" 
                   FontSize="28" TextColor="#2C3E50" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <Frame Grid.Row="1" 
               IsVisible="{Binding HasPendingRequests}" 
               BackgroundColor="#FFF3CD" Margin="0,0,0,15" Padding="10" CornerRadius="10">
            <CollectionView ItemsSource="{Binding PendingRequests}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PendingConnection">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="בקשת חיבור מהמשפחה" VerticalOptions="Center" TextColor="Black"/>
                            <Button Text="אשר" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ElderRemindersViewModel}}, Path=ApproveRequestCommand}" CommandParameter="{Binding .}" BackgroundColor="Green" TextColor="White" HeightRequest="35"/>
                            <Button Text="דחה" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ElderRemindersViewModel}}, Path=RejectRequestCommand}" CommandParameter="{Binding .}" BackgroundColor="Red" TextColor="White" HeightRequest="35"/>
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Frame>

        <CollectionView Grid.Row="2" ItemsSource="{Binding ElderRemindersList}" SelectionMode="None">

            <CollectionView.Header>
                <Frame BackgroundColor="#E67E22" CornerRadius="15" HasShadow="False" Padding="20" Margin="0,0,0,15">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                        <Label Text="{Binding WelcomeMessage}" 
                               FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="{Binding RemindersCountMessage}" 
                               FontSize="18" TextColor="White" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Reminder">
                    <Frame BackgroundColor="#1ABC9C" CornerRadius="15" Margin="0,10" Padding="20" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ElderRemindersViewModel}}, Path=NavigateToReminderDetailsCommand}" CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="Upcoming Remind:" 
                                   FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                <Label Text="{Binding Title}" FontSize="18" TextColor="White"/>
                                <Label Text="-" FontSize="18" TextColor="White"/>
                                <Label Text="{Binding DueDate, StringFormat='{0:HH:mm}'}" FontSize="18" TextColor="White"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>