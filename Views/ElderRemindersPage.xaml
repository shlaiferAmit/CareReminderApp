<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.ElderRemindersPage"
             x:DataType="viewmodels:ElderRemindersViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True"
             FlowDirection="LeftToRight">
    <ScrollView>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto" Padding="20" RowSpacing="15">

            <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,10,0,10">
                <Image Source="logo.png" HeightRequest="100" HorizontalOptions="Center"/>
                <Label Text="Welcome Home!" 
                       FontSize="32" FontAttributes="Bold" 
                       TextColor="#2C3E50" HorizontalOptions="Center"/>
                <Label Text="CareRemind" 
                       FontSize="24" TextColor="#2C3E50" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Frame Grid.Row="1" 
                   IsVisible="{Binding HasPendingRequests}" 
                   BackgroundColor="#FFF3CD" Margin="0,0,0,5" Padding="10" CornerRadius="10" HasShadow="False">
                <CollectionView ItemsSource="{Binding PendingRequests}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PendingConnection">
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="Family Connection Request" VerticalOptions="Center" TextColor="Black"/>
                                <Button Text="Accept" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ElderRemindersViewModel}}, Path=ApproveRequestCommand}" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="Green" TextColor="White" HeightRequest="35"/>
                                <Button Text="Decline" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ElderRemindersViewModel}}, Path=RejectRequestCommand}" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="Red" TextColor="White" HeightRequest="35"/>
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

            <Frame Grid.Row="2" BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="False" IsVisible="{Binding HasReminders}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding WelcomeMessage}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>
                    <ProgressBar Progress="{Binding ProgressValue}" ProgressColor="#1ABC9C" HeightRequest="12" ScaleY="2"/>
                    <Label Text="{Binding ProgressText}" FontSize="14" HorizontalOptions="Center" TextColor="#2C3E50" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Grid.Row="3" Spacing="10" IsVisible="{Binding HasReminders}">
                <Label Text="What's up next?" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Start" Margin="5,0"/>

                <Frame BackgroundColor="#1ABC9C" CornerRadius="20" Padding="10" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToReminderDetailsCommand}" CommandParameter="{Binding NextReminder}"/>
                    </Frame.GestureRecognizers>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="{Binding NextReminder.Title, FallbackValue='All Done!'}" 
                               FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                            <Label Text="At:" FontSize="20" TextColor="White" Opacity="0.9"/>
                            <Label Text="{Binding NextReminder.DueDate, StringFormat='{0:HH:mm}'}" 
                                   FontSize="24" FontAttributes="Bold" TextColor="White"/>
                        </HorizontalStackLayout>

                        <Label Text="Tap for details >" FontSize="18" TextColor="White" HorizontalOptions="Center" Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>