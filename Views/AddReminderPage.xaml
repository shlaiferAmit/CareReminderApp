<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.AddReminderPage"
             x:DataType="viewmodels:AddReminderViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True"
             Title="Add Reminder"
             FlowDirection="LeftToRight">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">

            <Label Text="{Binding SelectedElder.FirstName, StringFormat='New Reminder for {0}'}" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50" 
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center" />

            <VerticalStackLayout Spacing="5">
                <Label Text="Reminder Title" TextColor="#2C3E50" FontAttributes="Bold" />
                <Frame BackgroundColor="White" CornerRadius="10" Padding="5,0" HasShadow="False">
                    <Entry Placeholder="Enter title here..." 
                           Text="{Binding ReminderTitle, Mode=TwoWay}" 
                           HorizontalTextAlignment="Start" 
                           HeightRequest="60" 
                           TextColor="Black"/>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Select Date" TextColor="#2C3E50" FontAttributes="Bold" />
                <Frame BackgroundColor="White" CornerRadius="10" Padding="5,0" HasShadow="False">
                    <DatePicker Date="{Binding SelectedDate, Mode=TwoWay}" 
                                HeightRequest="60" 
                                TextColor="Black"/>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Additional Notes" TextColor="#2C3E50" FontAttributes="Bold" />
                <Frame BackgroundColor="White" CornerRadius="10" Padding="10" HasShadow="False">
                    <Editor Placeholder="Add details or instructions..." 
                            Text="{Binding Notes, Mode=TwoWay}" 
                            HorizontalTextAlignment="Start"
                            HeightRequest="150" 
                            TextColor="Black"/>
                </Frame>
            </VerticalStackLayout>

            <Button Text="Save and Send Reminder" 
                    Command="{Binding SaveAndSendReminderCommand}"
                    BackgroundColor="#1ABC9C" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    CornerRadius="30" 
                    HeightRequest="65"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>