<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CareReminderApp.Views.AddReminderPage"
             Title="Add Reminder">
    <StackLayout Padding="20" Spacing="10">
        <Entry Placeholder="Title" Text="{Binding Title}" />
        <Editor Placeholder="Description" Text="{Binding Description}" HeightRequest="100"/>
        <DatePicker Date="{Binding ReminderDate}" />
        <Button Text="Add Reminder" Command="{Binding AddReminderCommand}" />
    </StackLayout>
</ContentPage>