<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#99C1E9">
    <VerticalStackLayout Spacing="20" Padding="30">
        <Label Text="{Binding ProfileTitle}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Frame BackgroundColor="White" CornerRadius="20" Padding="20">
            <VerticalStackLayout Spacing="10">
                <Ellipse Fill="#E67E22" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center"/>

                <Label Text="{Binding DisplayUser.FirstName}" FontSize="20" HorizontalOptions="Center"/>
                <Label Text="{Binding DisplayUser.UserEmail}" FontSize="14" HorizontalOptions="Center"/>

                <Button Text="Edit Profile" 
                    Command="{Binding EditProfileCommand}"
                    IsVisible="{Binding IsMyPersonalProfile}"
                    BackgroundColor="#3498DB" Margin="0,10"/>

                <VerticalStackLayout IsVisible="{Binding IsViewingElder}">
                    <Label Text="Reminders List" FontAttributes="Bold" Margin="0,10,0,5"/>
                    <CollectionView ItemsSource="{Binding Reminders}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Reminder">
                                <Frame Margin="0,5" Padding="10" BackgroundColor="#E1F5FE">
                                    <Label Text="{Binding Title}" />
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button Text="Add New Reminder" 
                        Command="{Binding AddReminderCommand}"
                        BackgroundColor="#2ECC71" Margin="0,10"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>