<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto, *, 80">

        <Label Grid.Row="0" Text="My Profile" 
               FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"
               TextColor="#2C3E50" Margin="0,20,0,10"/>

        <ScrollView Grid.Row="1">
            <Frame BackgroundColor="White" 
                   Margin="30,20" 
                   Padding="30" 
                   CornerRadius="0" 
                   HasShadow="False"
                   HorizontalOptions="FillAndExpand"
                   VerticalOptions="Start">

                <VerticalStackLayout Spacing="20">

                    <Frame CornerRadius="75" 
                           HeightRequest="150" 
                           WidthRequest="150" 
                           BackgroundColor="#E67E22" 
                           Padding="0" 
                           HorizontalOptions="Center"
                           BorderColor="Transparent">
                        <Label Text="**image" 
                               TextColor="White" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" 
                               FontAttributes="Bold"/>
                    </Frame>

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Start">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="Full name: " FontAttributes="Bold" />
                            <Label Text="{Binding DisplayUser.FirstName}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="5">
                            <Label Text="Email: " FontAttributes="Bold" />
                            <Label Text="{Binding DisplayUser.UserEmail}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="5">
                            <Label Text="Phone: " FontAttributes="Bold" />
                            <Label Text="{Binding DisplayUser.Mobile, StringFormat='Phone: {0}'}" 
       FontSize="18" 
       TextColor="#2C3E50"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    
                    <Button Text="Edit Profile" 
                            Command="{Binding EditProfileCommand}"
                            BackgroundColor="#3498DB" 
                            TextColor="White" 
                            CornerRadius="5" 
                            HeightRequest="45"
                            WidthRequest="200"
                            HorizontalOptions="Center"
                            Margin="0,20,0,0"/>
                </VerticalStackLayout>
            </Frame>
        </ScrollView>


    </Grid>
</ContentPage>