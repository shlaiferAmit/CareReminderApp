<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#99C1E9"
            >
    <Grid RowDefinitions="*, 80">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20" Padding="30">
                <Label Text="{Binding ProfileTitle}" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       TextColor="#2C3E50"/>

                <Frame BackgroundColor="White" 
                       CornerRadius="20" 
                       Padding="20" 
                       HasShadow="True" 
                       BorderColor="Transparent">

                    <VerticalStackLayout Spacing="10">
                        <Grid HorizontalOptions="Center" WidthRequest="110" HeightRequest="110">
                            <Frame CornerRadius="55" 
           HeightRequest="110" 
           WidthRequest="110" 
           Padding="0" 
           IsClippedToBounds="True"
           BorderColor="#E67E22">

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ChangePhotoCommand}" />
                                </Frame.GestureRecognizers>

                                <Image Source="{Binding ProfileImageSource}" 
               Aspect="AspectFill"
               HeightRequest="110" 
               WidthRequest="110"/>
                            </Frame>

                            <ImageButton Source="camera_icon.png"
                 Command="{Binding ChangePhotoCommand}"
                 IsVisible="{Binding IsMyPersonalProfile}"
                 BackgroundColor="White"
                 CornerRadius="15"
                 HeightRequest="50" 
                 WidthRequest="50"
                 VerticalOptions="End" 
                 HorizontalOptions="End"
                 Padding="5"
                 Margin="0,0,-5,-5">
                                <ImageButton.Shadow>
                                    <Shadow Brush="Black" Offset="2,2" Radius="5" Opacity="0.2"/>
                                </ImageButton.Shadow>
                            </ImageButton>
                        </Grid>

                        <Label Text="{Binding DisplayUser.FirstName}" 
                               FontSize="20" 
                               HorizontalOptions="Center" 
                               FontAttributes="Bold" 
                               TextColor="Black"/>

                        <Label Text="{Binding DisplayUser.UserEmail}" 
                               FontSize="14" 
                               HorizontalOptions="Center" 
                               TextColor="Gray"/>

                        <Button Text="Edit Details" 
                                Command="{Binding EditProfileCommand}"
                                IsVisible="{Binding IsMyPersonalProfile}"
                                BackgroundColor="#3498DB" 
                                CornerRadius="10"
                                Margin="0,10,0,0"/>

                        <VerticalStackLayout IsVisible="{Binding IsViewingElder}">
                            <Label Text="Reminders List" 
                                   FontAttributes="Bold" 
                                   Margin="0,10,0,5" 
                                   TextColor="#2C3E50"/>

                            <CollectionView ItemsSource="{Binding Reminders}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Reminder">
                                        <Frame Margin="0,5" 
                                               Padding="10" 
                                               BackgroundColor="#E1F5FE" 
                                               CornerRadius="10">
                                            <Label Text="{Binding Title}" 
                                                   TextColor="#2C3E50"/>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>



    </Grid>
</ContentPage>