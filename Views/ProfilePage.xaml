<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, 80">

        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="End" Spacing="4" Margin="0,10,15,0">
            <HorizontalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
            </HorizontalStackLayout.GestureRecognizers>
            <Image Source="logingout.png" WidthRequest="30" HeightRequest="30" VerticalOptions="Center"/>
            <Label Text="Logout" TextColor="#2C3E50" FontAttributes="Bold" VerticalOptions="Center" FontSize="16"/>
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="30">
                <Label Text="{Binding ProfileTitle}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>

                <Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Grid WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                            <Ellipse Fill="#E67E22"/>
                            <Label Text="image" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontSize="12"/>
                        </Grid>

                        <Label Text="{Binding DisplayUser.FirstName}" FontSize="20" HorizontalOptions="Center" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="{Binding DisplayUser.UserEmail}" FontSize="14" HorizontalOptions="Center" TextColor="Gray"/>

                        <Button Text="Edit Profile" 
                                Command="{Binding EditProfileCommand}"
                                IsVisible="{Binding IsMyPersonalProfile}"
                                BackgroundColor="#3498DB" 
                                CornerRadius="10"
                                Margin="0,10"/>

                        <VerticalStackLayout IsVisible="{Binding IsViewingElder}">
                            <Label Text="Reminders List" FontAttributes="Bold" Margin="0,10,0,5" TextColor="#2C3E50"/>
                            <CollectionView ItemsSource="{Binding Reminders}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Reminder">
                                        <Frame Margin="0,5" Padding="10" BackgroundColor="#E1F5FE" CornerRadius="10" HasShadow="False">
                                            <Label Text="{Binding Title}" TextColor="#2C3E50"/>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Button Text="Add New Reminder" 
                                    Command="{Binding AddReminderCommand}"
                                    BackgroundColor="#2ECC71" 
                                    CornerRadius="10"
                                    Margin="0,10"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToHomeCommand}"/>
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="home.png" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center"/>
                <Label Text="Home" HorizontalOptions="Center" TextColor="#2C3E50" FontSize="14" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>