<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#99C1E9">

    <Grid RowDefinitions="Auto, *, Auto">
        <ImageButton Source="logout_icon.png" 
                     HorizontalOptions="Start" 
                     Margin="20" 
                     HeightRequest="30"
                     Command="{Binding LogoutCommand}"/>

        <VerticalStackLayout Grid.Row="1" Spacing="20" Padding="30" VerticalOptions="Center">
            <Label Text="My Profile" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>

            <Frame BackgroundColor="White" CornerRadius="15" HasShadow="False" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Ellipse Fill="#E67E22" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center"/>

                    <Label Text="{Binding CurrentUser.FirstName, StringFormat='First Name: {0}'}" TextColor="#2C3E50"/>
                    <Label Text="{Binding CurrentUser.LastName, StringFormat='Last Name: {0}'}" TextColor="#2C3E50"/>
                    <Label Text="{Binding CurrentUser.UserEmail, StringFormat='Email: {0}'}" TextColor="#2C3E50"/>
                    <Label Text="{Binding CurrentUser.Mobile, StringFormat='Phone: {0}'}" TextColor="#2C3E50"/>

                    <Button Text="Edit Profile" 
                            BackgroundColor="#3498DB" 
                            TextColor="White" 
                            Command="{Binding EditProfileCommand}"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <Button Grid.Row="2" Text="Home" BackgroundColor="White" TextColor="#2C3E50" 
                HeightRequest="60" Command="{Binding GoHomeCommand}"/>
    </Grid>
</ContentPage>