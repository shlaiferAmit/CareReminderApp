<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ProfilePage"
             x:DataType="viewModels:ProfileViewModel"
             BackgroundColor="#99C1E9"
             Title="My Profile">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <Label Text="CareRemind" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
            <Label Text="User Profile" FontSize="18" HorizontalOptions="Center" TextColor="#2C3E50"/>
        </VerticalStackLayout>

        <Frame Grid.Row="1" CornerRadius="15" BackgroundColor="White" HasShadow="True" VerticalOptions="Start">
            <VerticalStackLayout Spacing="15">
                <Ellipse Fill="#7F8C8D" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center"/>

                <Label Text="First Name:" FontAttributes="Bold" TextColor="Gray"/>
                <Label Text="{Binding CurrentUser.FirstName}" FontSize="18" TextColor="#2C3E50"/>
                <Label Text="Email:" FontAttributes="Bold" TextColor="Gray"/>
                <Label Text="{Binding CurrentUser.UserEmail}" FontSize="18" TextColor="#2C3E50"/>
                <Label Text="Account Type:" FontAttributes="Bold" TextColor="Gray"/>
                <Label Text="{Binding RoleName}" FontSize="18" TextColor="#2C3E50"/>
            </VerticalStackLayout>
        </Frame>

        <Button Grid.Row="2" 
                Text="Log Out" 
                Command="{Binding LogoutCommand}"
                BackgroundColor="#E67E22" 
                TextColor="White" 
                CornerRadius="10"
                HeightRequest="50"
                Margin="0,20,0,0"/>
    </Grid>
</ContentPage>