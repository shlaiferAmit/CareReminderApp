<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True"
             FlowDirection="LeftToRight">
    <Grid RowDefinitions="Auto, *">

        <Label Grid.Row="0" Text="My Profile" 
               FontSize="32" FontAttributes="Bold"
               HorizontalOptions="Center" 
               TextColor="#2C3E50" Margin="0,20,0,10"/>

        <ScrollView Grid.Row="1">
            <Frame BackgroundColor="White" 
                   Margin="25,10,25,30" 
                   Padding="20" 
                   CornerRadius="15" 
                   HasShadow="True">

                <VerticalStackLayout Spacing="25">

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Grid HeightRequest="160" WidthRequest="160">
                            <Frame CornerRadius="80" 
                                   HeightRequest="160" 
                                   WidthRequest="160" 
                                   Padding="0" 
                                   IsClippedToBounds="True"
                                   HasShadow="False"
                                   BorderColor="#3498DB">
                                <Image Source="{Binding ProfileImageSource}" 
                                       Aspect="AspectFill" />
                            </Frame>

                            <Frame BackgroundColor="#3498DB"
                                   HeightRequest="40"
                                   WidthRequest="40"
                                   CornerRadius="20"
                                   Padding="0"
                                   HorizontalOptions="End"
                                   VerticalOptions="End"
                                   HasShadow="True">
                                <Label Text="📷" TextColor="White" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Frame>

                            <ImageButton Command="{Binding ChangePhotoCommand}"
                                         BackgroundColor="Transparent"
                                         HeightRequest="160"
                                         WidthRequest="160"
                                         CornerRadius="80"/>
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="15" Padding="10" HorizontalOptions="Fill">

                        <VerticalStackLayout Spacing="2" HorizontalOptions="Start">
                            <Label Text="Full Name" FontSize="12" TextColor="#7F8C8D" 
                                   FontAttributes="Bold" HorizontalTextAlignment="Start"/>
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="Start">
                                <Label Text="{Binding DisplayUser.FirstName}" FontSize="18" TextColor="#2C3E50"/>
                                <Label Text="{Binding DisplayUser.LastName}" FontSize="18" TextColor="#2C3E50"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#ECF0F1"/>

                        <VerticalStackLayout Spacing="2" HorizontalOptions="Start">
                            <Label Text="Email Address" FontSize="12" TextColor="#7F8C8D" 
                                   FontAttributes="Bold" HorizontalTextAlignment="Start"/>
                            <Label Text="{Binding DisplayUser.UserEmail}" FontSize="16" 
                                   TextColor="#2C3E50" HorizontalTextAlignment="Start"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#ECF0F1"/>

                        <VerticalStackLayout Spacing="2" HorizontalOptions="Start">
                            <Label Text="Phone Number" FontSize="12" TextColor="#7F8C8D" 
                                   FontAttributes="Bold" HorizontalTextAlignment="Start"/>
                            <Label Text="{Binding DisplayUser.Mobile}" FontSize="16" 
                                   TextColor="#2C3E50" HorizontalTextAlignment="Start"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <Button Text="EDIT PROFILE" 
                            Command="{Binding EditProfileCommand}"
                            BackgroundColor="#3498DB" 
                            TextColor="White" 
                            FontAttributes="Bold"
                            CornerRadius="25" 
                            HeightRequest="55"
                            Margin="10,10,10,0"/>

                </VerticalStackLayout>
            </Frame>
        </ScrollView>
    </Grid>
</ContentPage>