<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ReminderDetailsPage"
             x:DataType="viewmodels:ReminderDetailsViewModel"
             BackgroundColor="#99C1E9"
             Title="Reminder Details">

    <VerticalStackLayout Spacing="25" Padding="25" VerticalOptions="Center">

        <Frame BackgroundColor="#E67E22" CornerRadius="15" HasShadow="False" Padding="30">
            <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                <Label Text="{Binding SelectedReminder.Title}" 
                       FontSize="26" FontAttributes="Bold" TextColor="White" 
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                <Frame BackgroundColor="#1ABC9C" CornerRadius="20" Padding="15,5" HorizontalOptions="Center">
                    <Label Text="{Binding StatusText}" TextColor="White" FontAttributes="Bold"/>
                </Frame>
            </VerticalStackLayout>
        </Frame>

        <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="False">
            <VerticalStackLayout Spacing="10">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="Time:" FontAttributes="Bold" TextColor="#2C3E50"/>
                    <Label Text="{Binding SelectedReminder.DueDate, StringFormat='{0:HH:mm}'}" TextColor="#2C3E50"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="Date:" FontAttributes="Bold" TextColor="#2C3E50"/>
                    <Label Text="{Binding SelectedReminder.DueDate, StringFormat='{0:dd/MM/yyyy}'}" TextColor="#2C3E50"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <VerticalStackLayout Spacing="15">
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button Grid.Column="0" Text="Delete" 
                        BackgroundColor="#E74C3C" TextColor="White"
                        Command="{Binding DeleteCommand}" HeightRequest="65" CornerRadius="15"/>

                <Button Grid.Column="1" Text="Mark Done" 
                        BackgroundColor="#1ABC9C" TextColor="White"
                        Command="{Binding MarkAsDoneCommand}" HeightRequest="65" CornerRadius="15"/>
            </Grid>

            <Button Text="Undo / Mark Not Done" 
                    BackgroundColor="#F1C40F" TextColor="#2C3E50"
                    Command="{Binding MarkAsNotDoneCommand}" 
                    HeightRequest="60" CornerRadius="15" FontAttributes="Bold"/>
        </VerticalStackLayout>

    </VerticalStackLayout>
</ContentPage>