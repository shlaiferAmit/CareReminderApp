<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ReminderDetailsPage"
             x:DataType="viewmodels:ReminderDetailsViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True"
             Title="Reminder Details"
             FlowDirection="LeftToRight">
    <Grid VerticalOptions="Center">
        <Frame BackgroundColor="White" 
               CornerRadius="20" 
               Margin="25" 
               Padding="25" 
               HasShadow="True"
               HorizontalOptions="Fill">

            <VerticalStackLayout Spacing="30">

                <Frame BackgroundColor="#E67E22" 
                       CornerRadius="15" 
                       Padding="20" 
                       HasShadow="False"
                       BorderColor="Transparent">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding SelectedReminder.Title}" 
                               FontSize="26" 
                               FontAttributes="Bold" 
                               TextColor="White" 
                               HorizontalOptions="Center" 
                               HorizontalTextAlignment="Center"/>

                        <Frame BackgroundColor="#1ABC9C" 
                               CornerRadius="20" 
                               Padding="15,5" 
                               HorizontalOptions="Center"
                               HasShadow="False">
                            <Label Text="{Binding StatusText}" 
                                   TextColor="White" 
                                   FontSize="16"
                                   FontAttributes="Bold"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout Spacing="15" Padding="10" HorizontalOptions="Start">

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Start">
                        <Label Text="⏰" FontSize="22" VerticalOptions="Center"/>
                        <Label Text="Time:" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedReminder.DueDate, StringFormat='{0:HH:mm}'}" 
                               FontSize="18" TextColor="#2C3E50" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Start">
                        <Label Text="📅" FontSize="22" VerticalOptions="Center"/>
                        <Label Text="Date:" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedReminder.DueDate, StringFormat='{0:MMMM dd, yyyy}'}" 
                               FontSize="18" TextColor="#2C3E50" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Button Text="Mark as Done" 
                            BackgroundColor="#1ABC9C" 
                            TextColor="White"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="10"
                            Command="{Binding MarkAsDoneCommand}"/>

                    <Button Text="Mark as Not Done" 
                            BackgroundColor="#F1C40F" 
                            TextColor="#2C3E50"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="10"
                            Command="{Binding MarkAsNotDoneCommand}"/>

                    <Button Text="Delete Reminder" 
                            BackgroundColor="#D64550" 
                            TextColor="White"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="10"
                            Command="{Binding DeleteCommand}"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>