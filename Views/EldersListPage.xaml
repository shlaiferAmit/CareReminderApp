<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.EldersListPage"
             x:DataType="viewmodels:EldersListViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True"
             FlowDirection="LeftToRight">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Margin="0,10,0,20" Spacing="5">
            <Label Text="My Seniors"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"/>
            <Label Text="Manage your family connections" 
                   FontSize="16" 
                   TextColor="#2C3E50" 
                   Opacity="0.8"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <Frame Grid.Row="1" 
               Margin="10,0" 
               Padding="15,2" 
               CornerRadius="20" 
               HasShadow="False" 
               BackgroundColor="White"
               HeightRequest="55"
               BorderColor="Transparent">

            <SearchBar Placeholder="Search senior..."
                       BackgroundColor="Transparent"
                       FontSize="16"
                       CancelButtonColor="#2C3E50"
                       PlaceholderColor="#95A5A6"
                       HorizontalOptions="Fill"/>
        </Frame>

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadEldersCommand}"
                     Margin="0,15,0,0">

            <CollectionView ItemsSource="{Binding Elders}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:User">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               Margin="0,8" 
                               HasShadow="False"
                               BorderColor="Transparent">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EldersListViewModel}}, Path=GoToProfileCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">

                                <Frame Grid.Column="0"
                                       WidthRequest="55"
                                       HeightRequest="55"
                                       CornerRadius="27.5"
                                       BackgroundColor="#E67E22"
                                       Padding="0"
                                       HasShadow="False"
                                       BorderColor="Transparent">
                                    <Label Text="{Binding FirstName}" 
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="15"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding FirstName}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#2C3E50"/>
                                    <Label Text="Connected" 
                                           FontSize="13" 
                                           TextColor="#7F8C8D"/>
                                </VerticalStackLayout>

                                
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Margin="0,50" Spacing="10">
                        <Label Text="No seniors connected yet."
                               TextColor="#2C3E50"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Try searching or adding a new senior."
                               TextColor="#2C3E50"
                               Opacity="0.7"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>