<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models" 
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.EldersListPage"
             x:DataType="viewmodels:EldersListViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *, 80">

 

        <Label Grid.Row="1" 
               Text="My Seniors" 
               FontSize="36" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               TextColor="#2C3E50" 
               Margin="0,10,0,20"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Elders}" Margin="25,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:User">
                    <Frame BackgroundColor="White" 
                           CornerRadius="0" 
                           Margin="0,8" 
                           Padding="15" 
                           HasShadow="True"
                           BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EldersListViewModel}}, Path=GoToProfileCommand}"
                                CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>

                        <HorizontalStackLayout Spacing="20">
                            <Grid WidthRequest="70" HeightRequest="70">
                                <Ellipse Fill="#7F8C8D" />
                                <Label Text="image" 
                                       TextColor="White" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       FontSize="14"/>
                            </Grid>

                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding FirstName}" 
                                       FontSize="22" 
                                       TextColor="#2C3E50"/>
                                <Label Text="Grandmother" 
                                       FontSize="16" 
                                       TextColor="#7F8C8D"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="3" BackgroundColor="White" Padding="10">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToHomeCommand}"/>
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="home.png" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center"/>
                <Label Text="Home" HorizontalOptions="Center" TextColor="#2C3E50" FontSize="14" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>