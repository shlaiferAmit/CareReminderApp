<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.EldersListPage"
             x:DataType="viewmodels:EldersListViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- כותרת -->
        <Label Grid.Row="0"
               Text="My Seniors"
               FontSize="34"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="#1F2D3D"
               Margin="0,20,0,10"/>

        <!-- חיפוש -->
        <SearchBar Grid.Row="1"
                   Placeholder="Search senior..."
                   BackgroundColor="White"
                   Margin="20,0"
                   CancelButtonColor="#2C3E50"/>

        <!-- רשימה -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadEldersCommand}">

            <CollectionView ItemsSource="{Binding Elders}"
                            Margin="20,10"
                            HorizontalOptions="Center">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:User">

                        <Frame BackgroundColor="White"
                               CornerRadius="14"
                               Padding="10"
                               Margin="0,6"
                               HasShadow="True"
                               WidthRequest="280"
                               HorizontalOptions="Center">

                            <!-- לחיצה -->
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EldersListViewModel}}, Path=GoToProfileCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <HorizontalStackLayout Spacing="12"
                                                   HorizontalOptions="Center">

                                <!-- עיגול -->
                                <Frame WidthRequest="45"
                                       HeightRequest="45"
                                       CornerRadius="22"
                                       BackgroundColor="#7F8C8D"
                                       Padding="0"
                                       HasShadow="False">

                                    <Label Text="{Binding FirstName}" 
       HorizontalOptions="Center"
       VerticalOptions="Center"
       TextColor="White"
       FontAttributes="Bold"
       FontSize="16"/>
                                </Frame>

                                <!-- טקסט -->
                                <VerticalStackLayout VerticalOptions="Center"
                                                     HorizontalOptions="Center">

                                    <Label Text="{Binding FirstName}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#2C3E50"
                                           HorizontalTextAlignment="Center"/>

                                    <Label Text="Senior"
                                           FontSize="12"
                                           TextColor="#95A5A6"
                                           HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </HorizontalStackLayout>
                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- אם ריק -->
                <CollectionView.EmptyView>
                    <Label Text="No seniors connected yet."
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="0,50"/>
                </CollectionView.EmptyView>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>