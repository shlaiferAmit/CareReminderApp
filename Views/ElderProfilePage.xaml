<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ElderProfilePage"
             x:DataType="viewmodels:ElderProfileViewModel"
             Title="פרופיל מבוגר">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <Frame Grid.Row="0" BackgroundColor="White" CornerRadius="10" HasShadow="True" Margin="0,0,0,10">
            <VerticalStackLayout>
                <Label Text="{Binding Elder.FirstName}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="{Binding Elder.UserEmail}" HorizontalOptions="Center" TextColor="Gray"/>
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Reminders}" 
                        EmptyView="אין תזכורות למבוגר זה"
                        Margin="0,10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Reminder">
                    <Frame Padding="10" Margin="0,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontAttributes="Bold"/>
                            <Label Text="{Binding DueDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                Text="➕ הוספת תזכורת חדשה" 
                Command="{Binding AddReminderCommand}"
                BackgroundColor="#1976D2" 
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="20"
                HeightRequest="50"
                Margin="0,10,0,0" />
    </Grid>
</ContentPage>