<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.ElderProfilePage"
             x:DataType="viewmodels:ElderProfileViewModel"
             BackgroundColor="#A0CFFF" 
             Title="פרופיל מבוגר">
    <ScrollView>
        <Grid RowDefinitions="Auto, Auto" Padding="20" RowSpacing="20">

            <Frame Grid.Row="0" 
                   BackgroundColor="White" 
                   CornerRadius="0" 
                   HasShadow="True" 
                   Padding="25">

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border WidthRequest="120" 
                                HeightRequest="120" 
                                StrokeShape="RoundRectangle 60" 
                                BackgroundColor="#F18A43" 
                                StrokeThickness="0" 
                                HorizontalOptions="Center">
                            <Label Text="**image" 
                                   TextColor="White" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center" 
                                   FontAttributes="Bold"/>
                        </Border>

                        <Label Text="{Binding Elder.FirstName}" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="Black" 
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5" HorizontalOptions="Fill">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="תאריך לידה:" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="***" TextColor="Black"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="5">
                            <Label Text="טלפון:" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="***" TextColor="Black"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="5">
                            <Label Text="אימייל:" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="{Binding Elder.UserEmail}" TextColor="Black"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#EEEEEE" HorizontalOptions="Fill"/>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="רשימת תזכורות" 
                               FontSize="18" 
                               FontAttributes="Bold" 
                               TextColor="Black" 
                               HorizontalOptions="Center"
                               Margin="0,0,0,10"/>

                        <CollectionView ItemsSource="{Binding Reminders}" 
                                        EmptyView="אין תזכורות למבוגר זה">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Reminder">
                                    <Frame BackgroundColor="#3282CE" 
                                           CornerRadius="5" 
                                           Padding="10" 
                                           Margin="0,0,0,10" 
                                           HasShadow="False">
                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">

                                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                                <Label Text="{Binding Title}" 
                                                       TextColor="White" 
                                                       FontAttributes="Bold" 
                                                       FontSize="14"/>
                                                <Label Text="{Binding DueDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}" 
                                                       TextColor="#D0EFFF" 
                                                       FontSize="11"/>
                                            </VerticalStackLayout>

                                            <Frame Grid.Column="1" 
                                                   BackgroundColor="#23BFA0" 
                                                   CornerRadius="15" 
                                                   Padding="15,5" 
                                                   HasShadow="False" 
                                                   VerticalOptions="Center">
                                                <Label Text="Done" 
                                                       TextColor="White" 
                                                       FontSize="12" 
                                                       FontAttributes="Bold"/>
                                            </Frame>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Button Grid.Row="1"
                    Text="Add new reminder" 
                    Command="{Binding AddReminderCommand}"
                    BackgroundColor="#23BFA0" 
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="5"
                    HeightRequest="50"
                    HorizontalOptions="Fill"
                    Margin="0,0,0,20"/>

        </Grid>
    </ScrollView>
</ContentPage>