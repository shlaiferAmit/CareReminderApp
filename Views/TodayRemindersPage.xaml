<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.TodayRemindersPage"
             x:DataType="viewmodels:TodayRemindersViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *, 80">



        <Label Grid.Row="1" 
               Text="Today’s Remainds" 
               FontSize="32" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               TextColor="#2C3E50" 
               Margin="0,20,0,20"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Reminders}" Margin="30,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Reminder">
                    <Frame BackgroundColor="White" 
           CornerRadius="0" 
           Margin="0,10" 
           Padding="20" 
           HasShadow="True"
           BorderColor="Transparent">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer 
                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TodayRemindersViewModel}}, Path=NavigateToReminderDetailsCommand}"
                CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="{Binding Title}" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50" 
                   HorizontalOptions="Center"/>

                            <Button Text="{Binding IsCompleted, Converter={StaticResource StatusToTextConverter}}"
                    BackgroundColor="{Binding IsCompleted, Converter={StaticResource StatusToColorConverter}}"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="20"
                    Padding="25,0"
                    HeightRequest="45"
                    HorizontalOptions="Center"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TodayRemindersViewModel}}, Path=UpdateReminderStatusAsyncCommand}"
                    CommandParameter="{Binding .}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="3" BackgroundColor="White" Padding="10">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToHomeCommand}"/>
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="home.png" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center"/>
                <Label Text="Home" HorizontalOptions="Center" TextColor="#2C3E50" FontSize="14" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>