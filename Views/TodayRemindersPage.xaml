<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.TodayRemindersPage"
             Title="Today's Reminders">

    <CollectionView ItemsSource="{Binding Reminders}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Reminder">
                <Frame Margin="10" Padding="15" BorderColor="#1ABC9C">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="18"/>
                            <Label Text="{Binding Time, StringFormat='{0:HH:mm}'}" TextColor="Gray"/>
                        </VerticalStackLayout>
                        <CheckBox Grid.Column="1" IsChecked="{Binding IsCompleted}" 
                                  CheckedChanged="OnReminderStatusChanged"/>
                    </Grid>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>