<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             x:Class="CareReminderApp.Views.TodayRemindersPage"
             x:DataType="viewmodels:TodayRemindersViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True"
             FlowDirection="LeftToRight">

    <Grid RowDefinitions="Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Margin="0,10,0,20" Spacing="5" HorizontalOptions="Center">
            <Label Text="Today's Reminders" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50" 
                   HorizontalOptions="Center"/>
            <Label Text="Everything you need to do today" 
                   FontSize="16" 
                   TextColor="#2C3E50" 
                   Opacity="0.8"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Reminders}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Reminder">
                    <Frame BackgroundColor="White" 
                           CornerRadius="15" 
                           Margin="0,8" 
                           Padding="22" 
                           HasShadow="False"
                           BorderColor="Transparent">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TodayRemindersViewModel}}, Path=NavigateToReminderDetailsCommand}"
                                CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">

                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="{Binding DueDate, StringFormat='{0:HH:mm}'}" 
                                       FontSize="18" 
                                       FontAttributes="Bold" 
                                       TextColor="#2C3E50"/>
                                <Label Text="AM" FontSize="10" Opacity="0.6" HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <BoxView Grid.Column="1" WidthRequest="2" BackgroundColor="#EEEEEE" HorizontalOptions="Start"/>

                            <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                <Label Text="{Binding Title}" 
                                       FontSize="18" 
                                       FontAttributes="Bold" 
                                       TextColor="#2C3E50"
                                       LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                    Text="{Binding IsCompleted, Converter={StaticResource StatusToTextConverter}}"
                                    BackgroundColor="{Binding IsCompleted, Converter={StaticResource StatusToColorConverter}}"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    CornerRadius="20"
                                    HeightRequest="38"
                                    Padding="15,0"
                                    VerticalOptions="Center"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TodayRemindersViewModel}}, Path=UpdateReminderStatusAsyncCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>