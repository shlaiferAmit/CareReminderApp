<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.FamilyDashboardPage"
             x:DataType="viewmodels:FamilyDashboardViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto, Auto, *">

        <VerticalStackLayout Grid.Row="0" Margin="20,10">
            <Image Source="logo.png" HeightRequest="120" Margin="0,10"/>
            <Label Text="CareRemind" 
                   FontSize="30" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   TextColor="#2C3E50"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="15" Margin="25,10">
            <Frame BackgroundColor="#E67E22" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                <Label Text="{Binding WelcomeMessage}" 
                       TextColor="White" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center"/>
            </Frame>

            <Button Text="+ Add New Senior" 
                    BackgroundColor="#8E44AD" 
                    TextColor="White" 
                    CornerRadius="15" 
                    HeightRequest="55" 
                    FontAttributes="Bold"
                    Command="{Binding AddSeniorCommand}"/>
        </VerticalStackLayout>



    </Grid>
</ContentPage>