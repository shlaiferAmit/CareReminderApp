<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CareReminderApp.ViewModels"
             xmlns:models="clr-namespace:CareReminderApp.Models"
             x:Class="CareReminderApp.Views.FamilyDashboardPage"
             x:DataType="viewmodels:FamilyDashboardViewModel"
             BackgroundColor="#99C1E9"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,30,0,20">
            <Image Source="logo.png" 
                   HeightRequest="110" 
                   HorizontalOptions="Center"/>
            <Label Text="Welcome Home!" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50" 
                   HorizontalOptions="Center"/>
            <Label Text="CareRemind" 
                   FontSize="20" 
                   TextColor="#2C3E50" 
                   Opacity="0.8"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="15">

            <Frame BackgroundColor="#1ABC9C" 
                   CornerRadius="15" 
                   HasShadow="True" 
                   BorderColor="Transparent"
                   Padding="20">
                <Label Text="{Binding WelcomeMessage}" 
                       TextColor="White" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center"/>
            </Frame>

            <Button Text="+ Add New Senior" 
                    BackgroundColor="#2C3E50" 
                    TextColor="White" 
                    CornerRadius="15" 
                    HeightRequest="65" 
                    FontAttributes="Bold"
                    FontSize="18"
                    Command="{Binding AddSeniorCommand}"/>
        </VerticalStackLayout>

        <Grid Grid.Row="2" Margin="0,20,0,0">
        </Grid>

    </Grid>
</ContentPage>