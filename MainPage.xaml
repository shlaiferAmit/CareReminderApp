<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CareReminderApp.Views.MainPage"
             BackgroundColor="#99C1E9">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
        <Label Text="Welcome!" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
        <Label Text="Connecting seniors with faimly, easily" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>


        <Image Source="mainlogo.png" HeightRequest="260" HorizontalOptions="Center"/>


        <Button Text="Sign In" 
                Clicked="OnSignInClicked" 
                BackgroundColor="DarkSlateBlue" 
                TextColor="White" 
                HeightRequest="55"/>

        <Button Text="Sign Up" 
                Clicked="OnSignUpClicked" 
                BackgroundColor="Transparent" 
                BorderColor="DarkSlateBlue" 
                BorderWidth="2" 
                TextColor="DarkSlateBlue" 
                HeightRequest="55"/>
    </VerticalStackLayout>
</ContentPage>