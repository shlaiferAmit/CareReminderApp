<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CareReminderApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CareReminderApp"
    xmlns:views="clr-namespace:CareReminderApp.Views"
    x:Name="MyShell"
    FlyoutBehavior="Disabled"
    FlowDirection="LeftToRight" 
    Shell.BackgroundColor="#A1CFFF"
    Shell.ForegroundColor="Black">

    <ShellContent
        x:Name="MainPageContent"
        Title="Home"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" 
        FlyoutItemIsVisible="False"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:SignInPage}"
        Route="SignInPage" 
        FlyoutItemIsVisible="False"
        Shell.NavBarIsVisible="False" />

    <FlyoutItem Title="AppPages" FlyoutItemIsVisible="False">
        <ShellContent
            Title="Today's Reminders"
            ContentTemplate="{DataTemplate views:ElderRemindersPage}"
            Route="ElderRemindersPage" />

        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:FamilyDashboardPage}"
            Route="FamilyDashboardPage" />
    </FlyoutItem>

    <MenuItem x:Name="LogoutMenu" Clicked="OnLogoutClicked">
        <Shell.MenuItemTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="40, *" Padding="20">
                    <Image Source="logingout.png" HeightRequest="25" WidthRequest="25"/>
                    <Label Grid.Column="1" 
                           Text="Logout" 
                           TextColor="Black" 
                           VerticalOptions="Center" 
                           Margin="15,0,0,0" 
                           FontSize="18"
                           FontAttributes="Bold"/>
                </Grid>
            </DataTemplate>
        </Shell.MenuItemTemplate>
    </MenuItem>

</Shell>