<?xml version="1.0" encoding="UTF-8" ?>

<Shell
    x:Class="CareReminderApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CareReminderApp.Views">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate views:FamilyDashboardPage}"
        Route="FamilyDashboardPage" />

    <ShellContent
        Title="SignUp"
        ContentTemplate="{DataTemplate views:SignUpPage}"
        Route="SignUpPage" />

</Shell>